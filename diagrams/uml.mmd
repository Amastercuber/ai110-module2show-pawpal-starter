classDiagram
    class Task {
        +str description
        +str time
        +str pet_name
        +str frequency
        +bool completed
        +mark_complete()
    }

    class Pet {
        +str name
        +str species
        +list~Task~ tasks
        +add_task(task)
        +list_tasks()
    }

    class Owner {
        +str name
        +list~Pet~ pets
        +add_pet(pet)
        +get_all_tasks()
    }

    class Scheduler {
        +Owner owner
        +sort_by_time()
        +detect_conflicts()
        +filter_by_status(completed)
    }

    Owner "1" --> "many" Pet
    Pet "1" --> "many" Task
    Scheduler --> Owner
